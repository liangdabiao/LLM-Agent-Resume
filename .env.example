# ===== LLM（对话）=====
# 支持任何兼容 OpenAI 接口的服务（智谱 BigModel / OpenAI / 等）
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4.7-flashx
LLM_TEMPERATURE=0.0

# ===== Embedding（向量化）=====
# 智谱 embedding-3 默认 2048 维（可设为 256~2048）
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=2048

# ===== 向后兼容：若 LLM_*/EMBEDDING_* 未设置，则回退到下面统一配置 =====
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===== 向量数据库 =====
# 后端选择：chroma（默认，本地持久化）/ milvus（Milvus/Zilliz Cloud）
VECTOR_DB=chroma
CHROMA_PERSIST_DIR=./chroma_db

# ===== Milvus / Zilliz Cloud（VECTOR_DB=milvus 时生效）=====
# 可直接提供完整 URI，或提供 HOST + PORT 自动拼接
# MILVUS_URI=https://your-instance.zillizcloud.com
MILVUS_HOST=https://your-instance.serverless.cloud.zilliz.com.cn
MILVUS_PORT=80
MILVUS_TOKEN=your-milvus-token
MILVUS_COLLECTION=resume_screening
# 索引类型：AUTOINDEX / IVF_FLAT / HNSW 等
INDEX=AUTOINDEX

# ===== 服务 / 跨域 =====
# 允许的前端来源（逗号分隔），留空则允许所有来源
SERVER_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== 缓存 / 日志 =====
CACHE_DIR=./cache
LOG_LEVEL=INFO
